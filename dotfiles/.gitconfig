[user]
	name = Sides
	email = 20118558+csides@users.noreply.github.com
[alias]
	co = checkout
	st = status
	hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
	pub = push -u origin HEAD
[init]
	defaultBranch = main
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
# Machine-specific config (e.g. the GPG signing key generated by the pave) lives
# here so each machine keeps its own. Created on first run; safe if absent.
[include]
	path = ~/.gitconfig.local
